# ── Gemini AI ──────────────────────────────────────────────────────────────
# Get this from https://aistudio.google.com → "Get API Key"
GEMINI_API_KEY=

# ── Google OAuth2 ──────────────────────────────────────────────────────────
# Create these in Google Cloud Console → APIs & Services → Credentials
# See README for exact steps
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh token obtained from https://developers.google.com/oauthplayground
# See README for exact steps
GOOGLE_REFRESH_TOKEN=

# ── Email settings ─────────────────────────────────────────────────────────
# The Gmail address that will RECEIVE the full trainer report
TRAINER_EMAIL=trainer@yourgym.com

# Your gym's display name (used in client emails)
GYM_NAME=Your Gym Name

# ── Google Sheets ──────────────────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000
